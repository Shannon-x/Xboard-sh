APP_NAME=XBoard
APP_ENV=production
APP_KEY=base64:PZXk5vTuTinfeEVG5FpYv2l6WEhLsyvGpiWK7IgJJ60=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=xboard
DB_USERNAME=root
DB_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME=null
MAILGUN_DOMAIN=
MAILGUN_SECRET=

# google cloud storage
ENABLE_AUTO_BACKUP_AND_UPDATE=false
GOOGLE_CLOUD_KEY_FILE=config/googleCloudStorageKey.json
GOOGLE_CLOUD_STORAGE_BUCKET=

# Prevent reinstallation
INSTALLED=false

# ─── Feature Flags（可选）───
# 详见 config/feature_flags.php
# 不设置任何变量也能正常运行，本批所有安全修复在镜像升级后默认生效。
# 仅当你想做更严格的「拒收」级别校验，或前端已配合改造时，才需要打开下面的开关。
# FEATURE_PAYMENT_AMOUNT_CHECK=warn        # 默认 warn：仅记录异常 webhook，不拒收。可选 off | warn | enforce
# FEATURE_PAYMENT_SECRET_HIDE=false        # 默认 false：列表返回完整 config。前端改造后可切 true